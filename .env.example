# mod.io credentials — https://docs.mod.io/restapiref/#email-exchange
#
# Use your *game's* API key from the game's dashboard on mod.io (not the personal
# read-only key from https://mod.io/me/access).
MODIO_API_KEY=your_game_api_key_here

# Your game's numeric ID from the mod.io dashboard (routes auth to g-{id}.modapi.io).
MODIO_GAME_ID=51

# Release builds embed MODIO_API_KEY and MODIO_GAME_ID from this file (or the
# environment) at compile time. Dev mode still reads .env at runtime.

# Optional: custom API host from your game's dashboard (e.g. g-12345.modapi.io).
# MODIO_API_HOST=g-12345.modapi.io

# Optional: use mod.io test environment (api.test.mod.io).
# MODIO_USE_TEST_ENV=true

# Optional: Rust log verbosity (shown in the terminal when running tauri dev).
# RUST_LOG=modkistmkii_lib=debug

# Optional: Sentry DSN for error reporting (Rust panics, logs, and frontend errors).
# Frontend events are routed through the Tauri Sentry plugin to the Rust SDK.
# Leave unset to disable.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
