{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Modkist MKII",
  "version": "0.1.0",
  "identifier": "net.tnrd.modkistmkii",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run generate",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Modkist MKII",
        "width": 800,
        "height": 600,
        "backgroundColor": "#121214"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "bundleName": "Modkist MKII"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
